@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Admin Dashboard</h2>
<div class="row">
    <div class="col-md-3">
        <div class="card text-white bg-primary mb-3">
            <div class="card-body">
                <h5 class="card-title">Total Items</h5>
                <p class="card-text">@ViewBag.TotalItems</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-danger mb-3">
            <div class="card-body">
                <h5 class="card-title">Pending / With Admin</h5>
                <p class="card-text">@ViewBag.PendingItems</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-info mb-3">
            <div class="card-body">
                <h5 class="card-title">Enquiries</h5>
                <p class="card-text">@ViewBag.TotalEnquiries</p>
            </div>
        </div>
    </div>
    <div class="col-md-3">
        <div class="card text-white bg-warning mb-3">
            <div class="card-body">
                <h5 class="card-title">Notifications</h5>
                <p class="card-text">@ViewBag.TotalNotifications</p>
            </div>
        </div>
    </div>
</div>

<h3>Recent Items</h3>
@{
    var items = Lost_And_Found.Models.DataStore.Items.OrderByDescending(i => i.DateReported).Take(5);
}
<ul class="list-group">
@foreach(var it in items)
{
    <li class="list-group-item">@it.Title - @it.ReporterName (@it.DateReported.ToString("g")) - @it.Status</li>
}
</ul>
