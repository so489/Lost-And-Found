@model IEnumerable<Lost_And_Found.Models.LostItem>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Admin - Manage Items</h2>
<p>
    <a href="@Url.Action("Dashboard","Admin")" class="btn btn-primary">Dashboard</a>
    <a href="@Url.Action("Enquiries","Admin")" class="btn btn-info">Enquiries</a>
    <a href="@Url.Action("Notifications","Admin")" class="btn btn-warning">Notifications</a>
    <a href="@Url.Action("Logout","Admin")" class="btn btn-secondary">Logout</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Title</th>
            <th>Reporter</th>
            <th>Location</th>
            <th>Status</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var item in Model)
        {
            <tr>
                <td>@item.Id</td>
                <td>@item.Title</td>
                <td>@item.ReporterName</td>
                <td>@item.Location</td>
                <td>@item.Status</td>
                <td>
                    @if(item.Status != Lost_And_Found.Models.LostStatus.Found)
                    {
                        <form action="@Url.Action("MarkFound","Admin")" method="post" class="d-inline">
                            @Html.AntiForgeryToken()
                            <input type="hidden" name="id" value="@item.Id" />
                            <button class="btn btn-sm btn-success">Mark Found</button>
                        </form>
                    }
                    else
                    {
                        <span class="text-muted">No actions</span>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
