@model IEnumerable<Lost_And_Found.Models.Notification>
@{
    Layout = "~/Views/Shared/_Layout.cshtml";
}
<h2>Manage Notifications</h2>
<p>
    <a href="@Url.Action("Dashboard","Admin")" class="btn btn-primary">Dashboard</a>
    <a href="@Url.Action("Manage","Admin")" class="btn btn-secondary">Manage Items</a>
    <a href="@Url.Action("Enquiries","Admin")" class="btn btn-info">Enquiries</a>
</p>

<h4>Add Notification</h4>
@using (Html.BeginForm("AddNotification","Admin", FormMethod.Post))
{
    @Html.AntiForgeryToken()
    <div class="form-group">
        @Html.TextArea("Message", null, new { @class = "form-control", rows = 3 })
    </div>
    <button class="btn btn-success">Add</button>
}

@if(TempData["Error"] != null)
{
    <div class="alert alert-danger">@TempData["Error"]</div>
}

<h4 class="mt-3">Existing Notifications</h4>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Message</th>
            <th>Date</th>
            <th></th>
        </tr>
    </thead>
    <tbody>
        @foreach(var n in Model)
        {
            <tr>
                <td>@n.Id</td>
                <td>@n.Message</td>
                <td>@n.Date.ToString("g")</td>
                <td>
                    @using (Html.BeginForm("DeleteNotification","Admin", FormMethod.Post))
                    {
                        @Html.AntiForgeryToken()
                        @Html.Hidden("id", n.Id)
                        <button class="btn btn-sm btn-danger">Delete</button>
                    }
                </td>
            </tr>
        }
    </tbody>
</table>
